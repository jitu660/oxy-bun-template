{
  "name": "oxy-bun",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "start": "bun src/index.ts",
    "upgrade": "bun update --latest",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix",
    "unused": "knip"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "bun-git-hooks": "^0.3.1",
    "knip": "^6.0.2",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "git-hooks": {
    "pre-commit": "bun run lint && bun run fmt:check"
  }
}
